{
  "name": "sante-publique-carte",
  "version": "1.0.0",
  "description": "Cartographie participative des déserts médicaux en France",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node server/server.js",
    "import-finess": "node server/scripts/import-finess.js",
    "import-ameli": "node server/scripts/import-ameli-real.js",
    "import-ameli-profs": "node server/scripts/import-ameli-real.js --profs",
    "import-ameli-etabs": "node server/scripts/import-ameli-real.js --etabs",
    "import-ameli-geocode": "node server/scripts/import-ameli-real.js --geocode",
    "import-ameli-stats": "node server/scripts/import-ameli-real.js --stats",
    "migrate-supabase": "node server/scripts/migrate-to-supabase.js --all",
    "migrate-supabase-dry": "node server/scripts/migrate-to-supabase.js --dry-run",
    "import-pg": "node server/scripts/import-pg.js",
